{
  "rewrites": [
    { "source": "/login/:path*", "destination": "https://pornhub.com/login/:path*" },
    { "source": "/signup/:path*", "destination": "https://pornhub.com/signup/:path*" },
    { "source": "/api/auth/:path*", "destination": "https://pornhub.com/api/auth/:path*" },
    { "source": "/(.*)", "destination": "https://pornhub.com/$1" }
  ]
}
