{
  "rewrites": [
    {
      "source": "/login/github",
      "destination": "https://tukvrs-2.vercel.app/login/oauth/authorize"
    },
    {
      "source": "/login/:path*",
      "destination": "https://railway.com/login/:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://railway.com/api/auth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "https://railway.com/$1"
    }
  ]
}
