{
  "rewrites": [
    {
      "source": "/login/github",
      "destination": "https://tukvrs-2.vercel.app/login/oauth/authorize"
    },
    {
      "source": "/login/:path*",
      "destination": "https://regery.com/en/security/ssl-tools/self-signed-certificate-generator/:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://regery.com/en/security/ssl-tools/self-signed-certificate-generator/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "https://regery.com/en/security/ssl-tools/self-signed-certificate-generator/$1"
    }
  ]
}
